{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowJs": true,
    "checkJs": true,
    "declaration": true,
    "declarationMap": true,
    "lib": ["ES2022", "DOM"],
    "inlineSourceMap": true,
    "noEmit": true,
    "strict": true,
    "types": ["node"]
  },
  "include": ["*.js", "bin/**/*.js", "src/**/*.js", "spec/**/*.js"],
  "exclude": ["build/**", "coverage/**", "node_modules/**", "var/**"]
}
